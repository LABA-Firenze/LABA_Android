# Copia questo file come `keystore.properties` nella root del repo Android (è in .gitignore).
# Usa il file .jks della "upload key" registrata su Google Play (App integrity → App signing).
#
# Verifica SHA1 del keystore prima di caricare l'AAB:
#   keytool -list -v -keystore PERCORSO.jks -alias ALIAS
# L'SHA1 certificato deve coincidere con quello mostrato in Play Console per la chiave di upload.
#
# Esempio (path relativo alla root LABA_Android):
storeFile=upload-play.jks
storePassword=INSERISCI_PASSWORD_KEYSTORE
keyAlias=INSERISCI_ALIAS
keyPassword=INSERISCI_PASSWORD_CHIAVE
